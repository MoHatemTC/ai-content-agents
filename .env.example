LITELLM_BASE_URL=https://management.sprints.ai/litellm
LITELLM_API_KEY= # Your LiteLLM API key here — never commit the real key
DEFAULT_MODEL=FW-Kimi-K2.6

# ==========================================================
# MOCK_MODE controls the agent ONLY when you create it as:
#
#     agent = MentorAgent()
#
# It has NO effect if you explicitly pass:
#
#     MentorAgent(mock_mode=True)
#     MentorAgent(mock_mode=False)
#
# true  -> Use the hardcoded mock response.
# false -> Call the real LiteLLM API.
#
# Keep the example default at "true" so a fresh setup
# (copy .env.example -> .env) never makes live API calls
# by accident; set it to "false" only when you have a key.
# ==========================================================

MOCK_MODE=true
