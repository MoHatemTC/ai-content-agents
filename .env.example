# ==========================================================
# MOCK_MODE controls the agent ONLY when you create it as:
#
#     agent = MentorAgent()
#
# It has NO effect if you explicitly pass:
#
#     MentorAgent(mock_mode=True)
#     MentorAgent(mock_mode=False)
#
# true  -> Use the hardcoded mock response.
# false -> Call the real LiteLLM API.
# ==========================================================

MOCK_MODE=false